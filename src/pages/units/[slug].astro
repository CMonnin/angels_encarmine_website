---
import { Image, getImage } from 'astro:assets';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { url } from '../../lib/url';
import { PAINT_RECIPES } from '../../data/paint-recipes';

export async function getStaticPaths() {
  const units = await getCollection('units');
  return units.map((unit) => ({
    params: { slug: unit.id },
    props: { unit },
  }));
}

interface Props {
  unit: CollectionEntry<'units'>;
}

const { unit } = Astro.props;
const { Content } = await render(unit);

// The lightbox used to link the untouched original (up to ~900KB), which made the
// full-res view slow to appear. Serve a webp capped at this width instead, never
// upscaling past the source.
const LIGHTBOX_MAX_WIDTH = 2000;

const photos = await Promise.all(
  unit.data.photos.map(async (photo) => ({
    alt: photo.alt,
    thumb: photo.src,
    full: await getImage({
      src: photo.src,
      width: Math.min(LIGHTBOX_MAX_WIDTH, photo.src.width),
      format: 'webp',
    }),
  })),
);
---

<Base title={unit.data.name}>
  <p class="badge">{unit.data.role}</p>
  <h1>{unit.data.name}</h1>
  <p class="lede">
    {unit.data.company !== 'None' && `${unit.data.company} Company`}
    {unit.data.company !== 'None' && unit.data.remarks && ' · '}
    {unit.data.remarks}
  </p>

  {
    photos.length > 0 ? (
      <>
        <div class="photo-strip">
          {photos.map((photo) => (
            <figure>
              <a href={photo.full.src} class="photo-link">
                <Image src={photo.thumb} alt={photo.alt} width={960} format="webp" />
              </a>
              <figcaption>{photo.alt}</figcaption>
            </figure>
          ))}
        </div>
        <dialog id="lightbox">
          <img id="lightbox-img" src="" alt="" />
        </dialog>
      </>
    ) : (
      <p>
        <em>Not yet photographed.</em>
      </p>
    )
  }

  <div class="prose">
    <Content />
  </div>

  {
    unit.data.recipeAreas.length > 0 && (
      <>
        <h2>Paint recipe</h2>
        <p>
          {unit.data.recipeAreas.map((slug, i) => (
            <>
              {i > 0 && ' · '}
              <a href={url(`/recipes/#${slug}`)}>{PAINT_RECIPES[slug].label}</a>
            </>
          ))}
        </p>
      </>
    )
  }
</Base>

<style>
  #lightbox {
    padding: 0;
    border: none;
    background: transparent;
    max-width: 95vw;
    max-height: 95vh;
  }

  #lightbox::backdrop {
    background: rgba(0, 0, 0, 0.85);
  }

  #lightbox img {
    display: block;
    max-width: 95vw;
    max-height: 95vh;
    width: auto;
    height: auto;
    transition: opacity 120ms ease;
  }

  #lightbox[data-loading] img {
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    #lightbox img {
      transition: none;
    }
  }
</style>

<script>
  const lightbox = document.querySelector<HTMLDialogElement>('#lightbox');
  const lightboxImg = document.querySelector<HTMLImageElement>('#lightbox-img');

  if (lightbox && lightboxImg) {
    // An <img> keeps painting its last decoded frame until the new src loads, so
    // opening the dialog straight after assigning src flashes the previous photo.
    // Open immediately (responsive), but keep the image hidden until it can paint.
    let latestRequest = 0;

    document.querySelectorAll<HTMLAnchorElement>('.photo-link').forEach((link) => {
      link.addEventListener('click', async (event) => {
        event.preventDefault();
        const request = ++latestRequest;

        lightbox.setAttribute('data-loading', '');
        lightboxImg.src = link.href;
        lightboxImg.alt = link.querySelector('img')?.alt ?? '';
        lightbox.showModal();

        try {
          await lightboxImg.decode();
        } catch {
          // Superseded by a later click, or the image failed to load; either way
          // reveal it so a broken image is visible rather than silently blank.
        }

        // A slow decode must not un-hide a photo the user has already clicked past.
        if (request === latestRequest) lightbox.removeAttribute('data-loading');
      });
    });

    lightbox.addEventListener('click', (event) => {
      if (event.target === lightbox) lightbox.close();
    });
  }
</script>
